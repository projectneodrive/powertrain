{
    "//": [
        "Qt IntelliSense for this folder only. Deliberately NOT merged into the",
        "repo-root .vscode/c_cpp_properties.json: that file is auto-generated by",
        "PlatformIO for the STM32 firmware and gets overwritten on every build.",
        "",
        "compileCommands is the authoritative source -- it is produced by CMake",
        "(CMAKE_EXPORT_COMPILE_COMMANDS) and carries every Qt include dir and",
        "define exactly as the compiler saw them. Run build.ps1 -Target desktop",
        "once to generate it. The includePath below is only a fallback for when",
        "that file is missing or a file is not in it (e.g. a brand-new header)."
    ],
    "version": 4,
    "configurations": [
        {
            "name": "Qt Desktop (MinGW)",
            "compileCommands": "${workspaceFolder}/build-desktop/compile_commands.json",
            "compilerPath": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64",
            "includePath": [
                "${workspaceFolder}/src",
                "C:/Qt/6.8.3/mingw_64/include",
                "C:/Qt/6.8.3/mingw_64/include/**"
            ],
            "defines": [
                "QT_CORE_LIB",
                "QT_GUI_LIB",
                "QT_WIDGETS_LIB",
                "QT_CHARTS_LIB"
            ]
        },
        {
            "name": "Qt WebAssembly (Emscripten)",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json",
            "compilerPath": "C:/emsdk/upstream/emscripten/em++.bat",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "clang-x64",
            "includePath": [
                "${workspaceFolder}/src",
                "C:/Qt/6.8.3/wasm_singlethread/include",
                "C:/Qt/6.8.3/wasm_singlethread/include/**",
                "C:/emsdk/upstream/emscripten/cache/sysroot/include"
            ],
            "defines": [
                "__EMSCRIPTEN__",
                "QT_CORE_LIB",
                "QT_GUI_LIB",
                "QT_WIDGETS_LIB",
                "QT_CHARTS_LIB"
            ]
        }
    ]
}
